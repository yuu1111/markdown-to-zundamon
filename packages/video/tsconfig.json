{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"noUncheckedIndexedAccess": true,
		"resolveJsonModule": true,
		"composite": true,
		"declaration": true,
		"declarationMap": true,
		"outDir": "dist",
		"rootDir": "src"
	},
	"include": ["src/**/*"],
	"references": [{ "path": "../core" }]
}
