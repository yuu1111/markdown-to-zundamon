{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"noUncheckedIndexedAccess": true,
		"resolveJsonModule": true
	},
	"include": ["src/**/*", "scripts/**/*", "remotion.config.ts"],
	"exclude": ["node_modules"]
}
