{
	"name": "markdown-to-zundamon",
	"private": true,
	"workspaces": [
		"packages/core",
		"packages/cli",
		"packages/video"
	],
	"scripts": {
		"preprocess": "bun packages/cli/src/preprocess.ts",
		"fetch": "bun packages/cli/src/fetch.ts",
		"studio": "bun packages/cli/src/studio.ts",
		"render": "bun packages/cli/src/render.ts",
		"typecheck": "tsc --build",
		"lint": "biome check .",
		"format": "biome check --write --unsafe .",
		"knip": "knip-bun",
		"similarity": "similarity-ts ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"knip": "^5.85.0",
		"typescript": "^5.9.3"
	}
}
